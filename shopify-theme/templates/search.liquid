<div class="max-w-7xl mx-auto px-4 py-12">
  <h1 class="text-2xl font-black text-secondary uppercase mb-8">Search Results</h1>

  <div class="mb-12">
    <form action="/search" method="get" class="relative max-w-2xl">
      <input 
        type="text" 
        name="q" 
        value="{{ search.terms | escape }}"
        placeholder="Search for products..." 
        class="w-full pl-12 pr-4 py-4 bg-white border-2 border-gray-100 rounded-2xl focus:border-primary focus:ring-0 outline-none transition-all"
      >
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </form>
  </div>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="text-center py-20 bg-white rounded-2xl border-2 border-dashed border-gray-100">
        <p class="text-gray-500">No results found for "{{ search.terms }}".</p>
      </div>
    {% endif %}
  {% endif %}
</div>

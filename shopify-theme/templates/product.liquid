<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Breadcrumbs -->
  <nav class="flex items-center gap-2 text-xs text-gray-500 mb-6 overflow-x-auto whitespace-nowrap pb-2">
    <a href="/" class="hover:text-primary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    {% if collection %}
      <a href="{{ collection.url }}" class="hover:text-primary transition-colors">{{ collection.title }}</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    {% endif %}
    <span class="text-secondary font-bold truncate">{{ product.title }}</span>
  </nav>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 p-6 md:p-8">
      <!-- Left Column: Images -->
      <div class="lg:col-span-5 space-y-4">
        <div class="aspect-square rounded-xl bg-slate-50 overflow-hidden border border-gray-100 group relative">
          <img 
            src="{{ product.featured_image | image_url: width: 1000 }}" 
            alt="{{ product.title | escape }}"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          >
          {% if product.compare_at_price > product.price %}
            <div class="absolute top-4 left-4 bg-red-500 text-white px-3 py-1 rounded-full font-black text-sm shadow-lg">
              -{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%
            </div>
          {% endif %}
        </div>
        <div class="grid grid-cols-5 gap-2">
          {% for image in product.images %}
            <div class="aspect-square rounded-lg bg-slate-50 border cursor-pointer transition-all overflow-hidden {% if forloop.first %}border-primary ring-2 ring-primary/20{% else %}border-gray-100 hover:border-primary{% endif %}">
              <img src="{{ image | image_url: width: 200 }}" class="w-full h-full object-cover">
            </div>
          {% endfor %}
        </div>
      </div>

      <!-- Right Column: Details -->
      <div class="lg:col-span-7 flex flex-col">
        <div class="mb-6">
          <h1 class="text-lg md:text-xl font-bold text-secondary leading-tight mb-3">
            {{ product.title }}
          </h1>
          <div class="flex items-center gap-4 flex-wrap">
            <div class="flex items-center gap-1 text-yellow-500">
              {% for i in (1..5) %}
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              {% endfor %}
              <span class="text-sm font-bold text-secondary ml-1">4.8</span>
            </div>
            <span class="text-sm text-gray-300">|</span>
            <span class="text-sm text-primary font-bold hover:underline cursor-pointer">120 Verified Reviews</span>
            <span class="text-sm text-gray-300">|</span>
            <span class="text-sm text-gray-400 uppercase font-bold tracking-tighter">SKU: {{ product.variants.first.sku }}</span>
          </div>
        </div>

        <!-- Price Block -->
        <div class="bg-slate-50/50 p-6 rounded-2xl border border-slate-100 mb-6">
          <div class="flex items-baseline gap-4 mb-2">
            <span class="text-2xl font-bold text-primary">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="text-lg text-gray-400 line-through decoration-red-500/50">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <div class="flex items-center gap-2">
            <span class="bg-green-500 text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">IN STOCK</span>
            {% if product.compare_at_price > product.price %}
              <span class="text-xs font-bold text-green-600 uppercase">Save {{ product.compare_at_price | minus: product.price | money }} right now</span>
            {% endif %}
          </div>
        </div>

        <!-- Shipping Block -->
        <div class="space-y-4 mb-8 p-4 border border-gray-100 rounded-xl bg-white shadow-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gray-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div class="flex-1">
              <div class="flex justify-between items-center mb-1">
                <span class="text-sm font-bold text-secondary">Delivery to Nairobi</span>
                <button class="text-primary text-xs font-bold hover:underline">CHANGE</button>
              </div>
              <p class="text-xs text-gray-500">Standard Delivery: Get it by tomorrow</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            <p class="text-sm text-secondary"><span class="font-bold">Shipping Fee:</span> <span class="text-green-600 font-bold">FREE</span></p>
          </div>
        </div>

        <!-- Add to Cart Form -->
        <form action="/cart/add" method="post" enctype="multipart/form-data" class="space-y-6">
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          
          <div>
            <h3 class="text-sm font-black text-secondary uppercase mb-3 tracking-wider">Quantity</h3>
            <div class="flex items-center gap-4">
              <div class="flex items-center border-2 border-gray-100 rounded-xl overflow-hidden">
                <button type="button" class="px-4 py-2 hover:bg-gray-50 font-bold text-xl">-</button>
                <input type="number" name="quantity" value="1" min="1" class="w-12 text-center font-black text-secondary border-x-2 border-gray-100 focus:outline-none">
                <button type="button" class="px-4 py-2 hover:bg-gray-50 font-bold text-xl">+</button>
              </div>
              <span class="text-xs text-gray-500 font-medium">99+ pieces available</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <button type="submit" class="flex-1 bg-primary hover:bg-primary-dark text-white font-black py-4 text-lg rounded-xl shadow-xl shadow-primary/20 flex items-center justify-center gap-3 transition-all">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              ADD TO CART
            </button>
            <button type="button" class="flex-1 bg-secondary hover:bg-black text-white font-black py-4 text-lg rounded-xl shadow-xl shadow-secondary/20 transition-all">
              BUY NOW
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Description Section -->
  <div class="mt-12 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="border-b border-gray-100 flex">
      <button class="px-8 py-4 text-sm font-black uppercase tracking-wider text-primary border-b-2 border-primary">Description</button>
      <button class="px-8 py-4 text-sm font-black uppercase tracking-wider text-gray-500 hover:text-secondary">Specifications</button>
    </div>
    <div class="p-8">
      <h3 class="text-xl font-black text-secondary mb-4 uppercase">Product Details</h3>
      <div class="prose max-w-none text-gray-600 leading-relaxed">
        {{ product.description }}
      </div>
    </div>
  </div>
</div>

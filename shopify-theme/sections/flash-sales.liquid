<section class="bg-white rounded-2xl border-2 border-primary/10 overflow-hidden shadow-sm">
  <div class="bg-primary p-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center text-white">
        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <div>
        <h2 class="text-xl font-black text-white uppercase tracking-tight">Flash Sales</h2>
        <p class="text-white/80 text-[10px] uppercase font-bold tracking-widest">Limited Time Offer</p>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <span class="text-white/70 text-xs font-bold uppercase mr-2">Ends In:</span>
      <div class="flex gap-1.5">
        <div class="bg-white text-primary w-10 h-10 rounded-lg flex items-center justify-center font-black text-lg shadow-inner">12</div>
        <span class="text-white font-bold text-xl">:</span>
        <div class="bg-white text-primary w-10 h-10 rounded-lg flex items-center justify-center font-black text-lg shadow-inner">45</div>
        <span class="text-white font-bold text-xl">:</span>
        <div class="bg-white text-primary w-10 h-10 rounded-lg flex items-center justify-center font-black text-lg shadow-inner">00</div>
      </div>
    </div>

    <a href="/collections/flash-sales" class="bg-white/10 border border-white/20 text-white hover:bg-white hover:text-primary px-6 py-2 rounded-xl font-bold text-sm transition-all flex items-center gap-2">
      VIEW ALL <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {% for product in collections.flash-sales.products limit: 4 %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Flash Sales",
  "settings": []
}
{% endschema %}
